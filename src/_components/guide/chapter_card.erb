<a href="<%= @chapter.relative_url %>" class="card bg-base-200 shadow-sm hover:shadow-md border border-base-300 hover:border-primary/50 transition-all group">
  <div class="card-body relative min-h-26 py-6">
    <span
      class="pointer-events-none select-none absolute right-4 top-1/2 z-0 -translate-y-1/2 text-right text-[3.5rem] font-bold tabular-nums leading-none text-base-content/[0.07] transition-colors group-hover:text-primary/12 sm:right-7 sm:text-[6.25rem]"
      aria-hidden="true"
    ><%= @chapter.data.order %></span>
    <div class="relative z-10 min-w-0 pr-12 sm:pr-16">
      <h2 class="card-title text-base text-base-content group-hover:text-primary transition-colors mb-2"><%= @chapter.data.title %></h2>
      <% if @chapter.data.description %>
        <p class="text-sm text-base-content/70 line-clamp-3"><%= @chapter.data.description %></p>
      <% end %>
    </div>
  </div>
</a>
