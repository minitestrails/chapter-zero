<div class="max-w-6xl mx-auto px-4">
  <div class="alert flex bg-base-200 border border-base-300 shadow-sm flex-col sm:flex-row sm:items-center gap-4 py-4">
    <div class="flex-1 text-center sm:text-left">
      <p class="font-medium text-base-content">Missing a topic?</p>
      <p class="text-sm text-base-content/70 mt-0.5">Tell us what you'd like covered and we'll consider adding a chapter.</p>
    </div>
    <a
      href="<%= relative_url '/contact' %>?subject=Missing%20Topic"
      class="btn btn-outline btn-sm w-full sm:w-auto shrink-0"
