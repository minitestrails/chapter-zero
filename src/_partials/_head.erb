<% resource_title = strip_html(strip_newlines(title)) %>
<% site_metadata = site.data.site_metadata %>

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><% if resource_title != "Index" %><%= resource_title %> | <%= metadata.title %><% else %><%= metadata.title %>: <%= metadata.tagline %><% end %></title>

<meta name="description" content="<%= metadata.description %>">

<% if site_metadata.favicon_path.to_s.strip != "" %>
  <link rel="icon" href="<%= relative_url site_metadata.favicon_path %>" type="image/png" sizes="32x32">
<% end %>

<% if site_metadata.apple_touch_icon_path.to_s.strip != "" %>
  <link rel="apple-touch-icon" href="<%= relative_url site_metadata.apple_touch_icon_path %>">
<% end %>

<link rel="stylesheet" href="<%= asset_path :css %>">
<script src="<%= asset_path :js %>" defer></script>

<%= live_reload_dev_js %>

<%= seo %>

<% if site_metadata.google_analytics_id && ENV["BRIDGETOWN_ENV"] != "development" %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= site_metadata.google_analytics_id %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "<%= site_metadata.google_analytics_id %>", { send_page_view: true });
  </script>
<% end %>
