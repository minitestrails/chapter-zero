<!doctype html>
<html lang="<%= site.locale %>">
  <head>
    <%= render "head", metadata: site.metadata, title: data.title %>
  </head>

  <body class="min-h-screen flex flex-col <%= data.layout %> <%= data.page_class %>">
    <%= render Shared::SupportBanner.new %>
    <%= render "header" %>

    <main class="flex-1">
      <%= yield %>
    </main>

    <%= render "footer" %>
  </body>
</html>
