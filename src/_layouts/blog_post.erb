---
layout: default
---

<% post_date = data.date %>
<% formatted_date =
     if post_date.respond_to?(:strftime)
       post_date.strftime("%B %-d, %Y")
     else
       post_date.to_s
     end %>
<% tags = Array(data.tags).map { |t| t.to_s.strip }.reject(&:empty?) %>

<article class="max-w-4xl mx-auto px-4 py-10">
  <header class="relative mb-10 rounded-box border border-base-300 bg-base-200/50 overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-20 bg-gradient-to-br from-primary/15 via-primary/5 to-transparent pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-primary via-primary/50 to-transparent" aria-hidden="true"></div>

    <div class="relative px-6 py-8 sm:px-8 sm:py-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <% if formatted_date.to_s.strip != "" %>
          <time datetime="<%= post_date.to_s %>" class="badge badge-ghost badge-sm font-mono tracking-wide">
            <%= formatted_date %>
          </time>
        <% end %>
        <span class="badge badge-primary badge-sm">Blog</span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4"><%= data.title %></h1>

      <% if data.description %>
        <p class="text-lg text-base-content/70 leading-relaxed max-w-2xl"><%= data.description %></p>
      <% end %>

      <% if tags.any? %>
        <div class="flex flex-wrap gap-2 mt-5">
          <% tags.each_with_index do |tag, index| %>
            <span class="badge badge-sm <%= index.zero? ? 'badge-primary' : 'badge-outline' %>"><%= tag %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </header>

  <div class="prose prose-base max-w-none" data-controller="clipboard">
    <%= yield %>
  </div>

  <% unless data.hide_content_feedback %>
    <%= render Shared::ContentFeedback.new(
          label: "post",
          title: data.title
        ) %>
  <% end %>
</article>
